{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lesson Loom",
  "version": "0.2.0",
  "identifier": "com.michaelborck.lessonloom",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lesson Loom",
        "url": "app/index.html",
        "width": 1320,
        "height": 880,
        "minWidth": 900,
        "minHeight": 620,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "shortDescription": "AI-assisted lesson plan generator",
    "longDescription": "Upload teaching material, choose a pedagogical framework, and generate structured, timed lesson plans you can refine in conversation. Your material and API keys stay on your device.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
