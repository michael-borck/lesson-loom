# ---- Lesson Loom self-host configuration ----
# Copy to .env, fill in, then: docker compose up -d
# Configure at least one provider (Anthropic and/or OpenAI-compatible).

# Port the container listens on (compose maps it 1:1)
PORT=8080

# STRONGLY RECOMMENDED: a shared password users must enter in Settings.
# Without it, anyone who can reach this server can spend your API credits.
APP_PASSWORD=

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=
# Models offered in the UI (first is the default)
ANTHROPIC_MODELS=claude-opus-4-8,claude-sonnet-5,claude-haiku-4-5

# ---- OpenAI-compatible endpoint (OpenAI, OpenRouter, Ollama, vLLM, ...) ----
# Include the /v1 path. Examples:
#   https://api.openai.com/v1
#   https://openrouter.ai/api/v1
#   http://ollama:11434/v1        (an Ollama container on the same network)
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
# Models offered in the UI (first is the default)
OPENAI_COMPAT_MODELS=
# Display name shown in the app's Settings page
OPENAI_COMPAT_LABEL=Server model
